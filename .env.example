FAQ_CHATBOT_APP_NAME=faqchatbot
FAQ_CHATBOT_ENVIRONMENT=development
FAQ_CHATBOT_LOG_LEVEL=INFO
FAQ_CHATBOT_DEBUG=false
FAQ_CHATBOT_FAQ_DATA_PATH=data/faq.json
# Local default for host execution. Docker Compose overrides this to
# http://host.docker.internal:11434 so the app container uses host Ollama.
FAQ_CHATBOT_OLLAMA_BASE_URL=http://localhost:11434
# Required on the Ollama host for chat and ingestion.
FAQ_CHATBOT_OLLAMA_GENERATE_MODEL=qwen3.5:9b
FAQ_CHATBOT_OLLAMA_EMBEDDING_MODEL=nomic-embed-text-v2-moe
FAQ_CHATBOT_OLLAMA_TIMEOUT_SECONDS=30
FAQ_CHATBOT_OLLAMA_GENERATE_TEMPERATURE=0.2
FAQ_CHATBOT_OLLAMA_GENERATE_MAX_TOKENS=512
FAQ_CHATBOT_QDRANT_URL=http://localhost:6333
FAQ_CHATBOT_QDRANT_COLLECTION_NAME=faq_entries
FAQ_CHATBOT_QDRANT_TIMEOUT_SECONDS=30
FAQ_CHATBOT_TOP_K=3
FAQ_CHATBOT_SCORE_THRESHOLD=0.60
FAQ_CHATBOT_FALLBACK_MESSAGE=Leider konnte ich Ihre Frage nicht verstehen.
FAQ_CHATBOT_MAX_QUESTION_CHARS=500
FAQ_CHATBOT_USE_STUB_UI_SERVICE=false
FAQ_CHATBOT_QUERY_REWRITE_ENABLED=true
FAQ_CHATBOT_QUERY_REWRITE_BORDERLINE_MIN_SCORE=0.35
FAQ_CHATBOT_QUERY_REWRITE_MAX_VARIANTS=3
FAQ_CHATBOT_QUERY_REWRITE_TEMPERATURE=0.0
FAQ_CHATBOT_QUERY_REWRITE_MAX_TOKENS=96
